# ─── Required: Anthropic ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-5

# ─── Cross-device persistence + email-magic-link auth: Supabase ──
# Get these from https://supabase.com/dashboard/project/_/settings/api
# Only these two are needed — sync is client-side under Row-Level Security,
# so the public anon key is safe to expose. The service_role key is NOT used
# by the app (leave it unset unless a future server-side admin job needs it).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# SUPABASE_SERVICE_ROLE_KEY=  (optional / unused — keep secret if ever set)

# ─── Required for real chart math: Python sidecar ────────────
# Deploy /ephemeris-service/ to Railway (or any host that runs Python)
EPHEMERIS_URL=https://innerzenith-ephemeris.up.railway.app
EPHEMERIS_SHARED_SECRET=change-me-to-a-long-random-string

# ─── Required for voice readings: Azure TTS ──────────────────
# Create at https://portal.azure.com → "Speech service" → free F0 tier
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=centralindia
AZURE_SPEECH_VOICE=en-US-AnaNeural

# ─── Curator agent (LOCAL ONLY — runs on your machine, never deployed) ───────
# The curator polls a 3-model panel + cross-checks the classical texts.
# Without OpenAI/Gemini it runs Claude-only (cards land in review).
# Without the service_role key it writes curator/cards.jsonl instead of Supabase.
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=your-google-ai-studio-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # Supabase → Settings → API → service_role (SECRET)
# OPENAI_MODEL=gpt-4o
# GEMINI_MODEL=gemini-2.0-flash
# ARBITER_MODEL=claude-opus-4-5
